---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TagBadge from '../../components/TagBadge.astro';
import { getAllNotes } from '../../lib/notes.ts';

const allNotes = await getAllNotes();
const tagCounts = new Map<string, number>();
for (const note of allNotes) {
  for (const tag of note.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  }
}
const tags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="แท็กทั้งหมด" description="รวมแท็กทั้งหมดในฐานความรู้">
  <div class="mb-6">
    <h1 class="text-2xl font-semibold text-text">แท็กทั้งหมด</h1>
    <p class="mt-1 text-text-muted">{tags.length} แท็ก</p>
  </div>

  {tags.length > 0 ? (
    <div class="flex flex-wrap gap-2">
      {tags.map(([tag, count]) => <TagBadge tag={tag} count={count} />)}
    </div>
  ) : (
    <p class="text-text-muted">ยังไม่มีแท็ก</p>
  )}
</BaseLayout>
